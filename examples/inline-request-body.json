{
  "openapi": "3.0.2",
  "info": {
    "version": "0.0.0",
    "title": "Example API"
  },
  "servers": [
    {
      "url": "https://api.example.com/internal/sample"
    }
  ],
  "paths": {
    "/v1/records/{recordId}/items": {
      "put": {
        "parameters": [
          {
            "in": "path",
            "name": "recordId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "itemName": {
                      "type": "string"
                    },
                    "itemType": {
                      "type": "string",
                      "enum": [
                        "typeA",
                        "typeB",
                        "typeC",
                        "typeD"
                      ]
                    },
                    "contentType": {
                      "type": "string"
                    },
                    "itemId": {
                      "type": "string"
                    },
                    "version": {
                      "type": "number"
                    },
                    "groupId": {
                      "type": "string"
                    },
                    "relatedItemId": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "itemName",
                    "itemType",
                    "contentType",
                    "itemId",
                    "version"
                  ]
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1/records/{recordId}/missing-items": {
      "get": {
        "parameters": [
          {
            "in": "path",
            "name": "recordId",
            "required": true,
            "schema": {
              "type": "string",
              "format": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "itemType": {
                        "type": "string",
                        "enum": [
                          "typeA",
                          "typeB",
                          "typeC",
                          "typeD"
                        ]
                      },
                      "missingCount": {
                        "type": "number"
                      },
                      "contentTypes": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "basic": {
                    "summary": "Example of an array of missing items",
                    "value": [
                      {
                        "itemType": "typeA",
                        "missingCount": 2,
                        "contentTypes": [
                          "pdf",
                          "tiff",
                          "tif"
                        ]
                      },
                      {
                        "itemType": "typeC",
                        "missingCount": 1,
                        "contentTypes": [
                          "pdf"
                        ]
                      },
                      {
                        "itemType": "typeB",
                        "missingCount": 2,
                        "contentTypes": [
                          "dwg"
                        ]
                      }
                    ]
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
